# Server
PORT=4000
NODE_ENV=development

# Neon PostgreSQL (preferred — use the pooled connection string from Neon dashboard)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Local PostgreSQL fallback (only if DATABASE_URL is not set)
# PG_USER=postgres
# PG_HOST=localhost
# PG_DATABASE=audio_transcription
# PG_PASSWORD=your_password
# PG_PORT=5432

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# CORS — frontend origin (comma-separated for multiple)
FRONTEND_URL=http://localhost:3000

# Production (Render): set FRONTEND_URL to your Netlify URL, e.g.
# FRONTEND_URL=https://your-app.netlify.app
