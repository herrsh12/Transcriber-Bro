{
  "name": "transcriber-bro",
  "private": true,
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "start:backend": "npm start --prefix backend",
    "portfolio": "powershell -ExecutionPolicy Bypass -File scripts/portfolio-setup.ps1",
    "start:backend:tunnel": "powershell -ExecutionPolicy Bypass -File scripts/start-backend.ps1",
    "tunnel": "powershell -ExecutionPolicy Bypass -File scripts/start-tunnel.ps1",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api"
  }
}
