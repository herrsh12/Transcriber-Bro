# Copy to .env.local for local development

# Server-side API routes (preferred on Netlify — works at runtime)
BACKEND_URL=http://localhost:4000

# Legacy/build-time fallback (also set on Netlify if you prefer)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Razorpay public key (must match backend RAZORPAY_KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# Production (Netlify dashboard):
# BACKEND_URL=https://transcriber-bro.onrender.com
# NEXT_PUBLIC_BACKEND_URL=https://transcriber-bro.onrender.com
# NEXT_PUBLIC_RAZORPAY_KEY_ID=your_live_or_test_key
