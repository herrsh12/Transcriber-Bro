# Copy to .env.local for local development

# Express API (Render in production)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Razorpay public key (must match backend RAZORPAY_KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# Production (Netlify dashboard): set NEXT_PUBLIC_BACKEND_URL to your Render URL, e.g.
# NEXT_PUBLIC_BACKEND_URL=https://transcriber-bro-api.onrender.com
